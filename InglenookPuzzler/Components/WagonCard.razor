@inject WagonService WagonService

<div class="card h-100">
    @if (!string.IsNullOrEmpty(Wagon.ImagePath))
    {
        <img src="@Wagon.ImagePath" alt="@Wagon.Name"
             class="card-img-top" style="height: 160px; object-fit: cover;" />
    }
    else
    {
        <img src="@WagonImageHelper.GetImage(Wagon)" alt="@Wagon.WagonType?.Name"
             class="card-img-top" style="height: 160px; object-fit: contain; padding: 12px; background: var(--bs-body-bg);" />
    }

    <div class="card-body">
        <h6 class="card-title mb-1">@Wagon.Name</h6>
        @if (!string.IsNullOrEmpty(Wagon.RollingStockNumber))
        {
            <small class="text-muted d-block">№ @Wagon.RollingStockNumber</small>
        }
        <small class="text-muted d-block">@Wagon.WagonType?.Name</small>
        @if (Wagon.Era is not null)
        {
            <small class="text-muted d-block">Era @Wagon.Era.Name</small>
        }
        @if (!string.IsNullOrEmpty(Wagon.Color))
        {
            <small class="text-muted d-block">@Wagon.Color</small>
        }
        @if (!string.IsNullOrEmpty(Wagon.Notes))
        {
            <p class="card-text mt-2 small">@Wagon.Notes</p>
        }
    </div>

    <div class="card-footer d-flex justify-content-end gap-2">
        <button class="btn btn-sm btn-outline-secondary" @onclick="() => OnEdit.InvokeAsync(Wagon)" title="Edit">
            ✏️
        </button>
        <button class="btn btn-sm btn-outline-danger"
                @onclick="() => _showConfirm = true"
                title="Delete">
            🗑️
        </button>

        @if (_showConfirm)
        {
            <div class="modal fade show d-block" style="background:rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Delete Wagon</h5>
                        </div>
                        <div class="modal-body">
                            <p>Are you sure you want to delete <strong>@Wagon.Name @(!string.IsNullOrEmpty(Wagon.RollingStockNumber) ? Wagon.RollingStockNumber : "")</strong> ?</p>
                            <p class="text-muted small">This action cannot be undone.</p>
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-outline-secondary" @onclick="() => _showConfirm = false">
                                Cancel
                            </button>
                            <button class="btn btn-danger" @onclick="DeleteConfirmed">
                                Delete
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Wagon Wagon { get; set; } = default!;
    [Parameter] public EventCallback<Wagon> OnEdit { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }
    private bool _showConfirm;

    private async Task DeleteConfirmed()
    {
        _showConfirm = false;
        await OnDelete.InvokeAsync(Wagon.Id);
    }    
}