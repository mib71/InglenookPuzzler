@page "/wagons"
@inject WagonService WagonService
@inject WagonTypeService WagonTypeService
@inject EraService EraService

<PageTitle>Wagon Collection</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4>🚃 Wagon Collection</h4>
    <button class="btn btn-primary" @onclick="ShowAddForm">
        + Add Wagon
    </button>
</div>

@if (_wagons.Count < 8)
{
    <div class="alert alert-info d-flex justify-content-between align-items-center">
        <span>You need at least 8 wagons to generate a puzzle. Want a sample set to get started?</span>
        <button class="btn btn-sm btn-outline-primary ms-3" @onclick="GenerateSampleWagons">
            Generate sample wagons
        </button>
    </div>
}

@if (_showForm)
{
    <div class="card mb-4">
        <div class="card-header">
            @(_editingWagon is null ? "Add Wagon" : "Edit Wagon")
        </div>
        <div class="card-body">
            <WagonForm EditModel="@_editingWagon"
                       OnSaved="OnWagonSaved"
                       OnCancelled="OnCancelled" />
        </div>
    </div>
}

<!-- FILTER -->
<div class="d-flex gap-2 mb-4 flex-wrap">
    <select class="form-select w-auto" @onchange="e => { _filterTypeId = int.Parse(e.Value!.ToString()!); _currentPage = 1; }">
        <option value="0">All Types</option>
        @foreach (var type in _wagonTypes)
        {
            <option value="@type.Id">@type.Name</option>
        }
    </select>
    <select class="form-select w-auto" @onchange="e => { _filterEraId = int.Parse(e.Value!.ToString()!); _currentPage = 1; }">
        <option value="0">All Eras</option>
        @foreach (var era in _eras)
        {
            <option value="@era.Id">@era.Name</option>
        }
    </select>
</div>

@if (_wagons.Count == 0)
{
    <p class="text-muted">No wagons yet. Add your first wagon above!</p>
}
else
{
    <div class="row g-3">
        @foreach (var wagon in PagedWagons)
        {
            <div class="col-md-4 col-lg-3">
                <WagonCard Wagon="@wagon"
                           OnEdit="EditWagon"
                           OnDelete="DeleteWagon" />
            </div>
        }
    </div>
}

@if (TotalPages > 1)
{
    <div class="d-flex justify-content-center align-items-center gap-3 mt-4">
        <button class="btn btn-sm btn-outline-secondary"
                @onclick="() => _currentPage--"
                disabled="@(_currentPage == 1)">
            ← Previous
        </button>
        <span class="text-muted small">Page @_currentPage of @TotalPages</span>
        <button class="btn btn-sm btn-outline-secondary"
                @onclick="() => _currentPage++"
                disabled="@(_currentPage == TotalPages)">
            Next →
        </button>
    </div>
}

@code {
    private List<Wagon> _wagons = new();
    private Wagon? _editingWagon;
    private bool _showForm;
    private int _filterTypeId;
    private int _filterEraId;
    private List<WagonType> _wagonTypes = new();
    private List<Era> _eras = new();
    private int _currentPage = 1;
    private int _pageSize = 12;

    private IEnumerable<Wagon> FilteredWagons => _wagons
        .Where(w => _filterTypeId == 0 || w.WagonTypeId == _filterTypeId)
        .Where(w => _filterEraId == 0 || w.EraId == _filterEraId);

    private IEnumerable<Wagon> PagedWagons => FilteredWagons
        .Skip((_currentPage - 1) * _pageSize)
        .Take(_pageSize);

    private int TotalPages => (int)Math.Ceiling(FilteredWagons.Count() / (double)_pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadWagons();
        _wagonTypes = await WagonTypeService.GetAllAsync();
        _eras = await EraService.GetAllAsync();
    }

    private async Task LoadWagons()
    {
        _wagons = await WagonService.GetAllAsync();
    }

    private void ShowAddForm()
    {
        _editingWagon = null;
        _showForm = true;
    }

    private void EditWagon(Wagon wagon)
    {
        _editingWagon = wagon;
        _showForm = true;
    }

    private async Task OnWagonSaved(Wagon wagon)
    {
        if (wagon.Id == 0)
            await WagonService.AddAsync(wagon);
        else
            await WagonService.UpdateAsync(wagon);

        _showForm = false;
        _editingWagon = null;
        await LoadWagons();
    }

    private async Task OnCancelled()
    {
        _showForm = false;
        _editingWagon = null;
    }

    private async Task DeleteWagon(int id)
    {
        await WagonService.DeleteAsync(id);
        await LoadWagons();
    }

    private async Task GenerateSampleWagons()
    {
        await WagonService.GenerateSampleWagonsAsync();
        await LoadWagons();
    }
}