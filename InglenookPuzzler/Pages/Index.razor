@page "/"
@inject WagonService WagonService
@inject PuzzleSessionService PuzzleSessionService

<PageTitle>Inglenook Puzzler</PageTitle>

<div class="row g-4 mb-4">
    <div class="col-12">
        <h1 class="mb-1">Plan. Shunt. Solve.</h1>
        <p class="text-muted">Become the master of the yard. Simple rules. Surprisingly deep strategy.</p>        
    </div>
</div>

<!-- HOW IT WORKS -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <p class="text-muted text-uppercase fw-bold small letter-spacing mb-0">How it works</p>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <span class="border border-warning text-warning rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width:36px;height:36px;flex-shrink:0;">1</span>
                    <h6 class="mb-0 fw-bold">Study the Yard</h6>
                </div>
                <p class="text-muted small mb-0">Each puzzle gives you a goal and a starting layout.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <span class="border border-warning text-warning rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width:36px;height:36px;flex-shrink:0;">2</span>
                    <h6 class="mb-0 fw-bold">Plan Your Moves</h6>
                </div>
                <p class="text-muted small mb-0">Use the headshunt and sidings to rearrange the wagons.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <span class="border border-warning text-warning rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width:36px;height:36px;flex-shrink:0;">3</span>
                    <h6 class="mb-0 fw-bold">Solve Efficiently</h6>
                </div>
                <p class="text-muted small mb-0">Reach the goal in as few moves as possible.</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">

    <!-- COLLECTION STATS -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">🚃 Collection</div>
            <div class="card-body">
                @if (_loadingCollection)
                {
                    <p class="text-muted">Loading...</p>
                }
                else
                {
                    <div class="mb-3">
                        <span class="fs-1 fw-bold">@_totalWagons</span>
                        <span class="text-muted ms-2">wagons in collection</span>
                    </div>
                    @if (_wagonsByType.Any())
                    {
                        <table class="table table-sm">
                            <tbody>
                                @foreach (var (type, count) in _wagonsByType)
                                {
                                    <tr>
                                        <td>@type</td>
                                        <td class="text-end fw-bold">@count</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    <a href="/wagons" class="btn btn-sm btn-outline-secondary mt-2">View Collection</a>
                }
            </div>
        </div>
    </div>

    <!-- PUZZLE STATS -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">🎯 Puzzle Stats</div>
            <div class="card-body">
                @if (_loadingPuzzle)
                {
                    <p class="text-muted">Loading...</p>
                }
                else if (_totalSolved == 0)
                {
                    <p class="text-muted fst-italic">No puzzles solved yet. <a href="/puzzle/setup">Start one!</a></p>
                }
                else
                {
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <div class="border rounded p-3 text-center">
                                <div class="fs-1 fw-bold">@_totalSolved</div>
                                <div class="text-muted small">Puzzles solved</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3 text-center">
                                <div class="fs-1 fw-bold">@_bestMoves</div>
                                <div class="text-muted small">Best score (moves)</div>
                            </div>
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <div class="border rounded p-3 text-center">
                                <div class="fs-1 fw-bold">@_averageMoves</div>
                                <div class="text-muted small">Average moves</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3 text-center">
                                <div class="fs-1 fw-bold">@_streak 🔥</div>
                                <div class="text-muted small">Current streak (days)</div>
                            </div>
                        </div>
                    </div>
                    @if (_lastSolved is not null)
                    {
                        <div class="text-muted small">
                            Last solved: @_lastSolved.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                            — @_lastSolved.MoveCount moves
                        </div>
                    }
                    
                }
            </div>
        </div>
    </div>

    <p class="text-muted small mt-0">
        Simple rules. Surprisingly deep strategy. Over 40,000 possible combinations.
        <a href="https://en.wikipedia.org/wiki/Inglenook_Sidings" target="_blank" class="text-muted">
            Learn more ↗
        </a>
    </p>
</div>

@code {
    private int _totalWagons;
    private List<(string Type, int Count)> _wagonsByType = new();
    private bool _loadingCollection = true;
    private double _averageMoves;
    private int _totalSolved;
    private int _bestMoves;
    private PuzzleSession? _lastSolved;
    private bool _loadingPuzzle = true;
    private int _streak;
    
    protected override async Task OnInitializedAsync()
    {
        var wagons = await WagonService.GetAllAsync();
        _totalWagons = wagons.Count;
        _wagonsByType = wagons
            .GroupBy(w => w.WagonType?.Name ?? "Unknown")
            .Select(g => (g.Key, g.Count()))
            .OrderByDescending(x => x.Item2)
            .ToList();
        _loadingCollection = false;

        var sessions = await PuzzleSessionService.GetCompletedAsync();
        _totalSolved = sessions.Count;
        _bestMoves = sessions.Any() ? sessions.Min(s => s.MoveCount) : 0;
        _lastSolved = sessions.FirstOrDefault();
        _loadingPuzzle = false;
        _averageMoves = sessions.Any() ? Math.Round(sessions.Average(s => s.MoveCount), 1) : 0;

        _streak = await PuzzleSessionService.GetCurrentStreakAsync();
    }    
}